  <div class="day-section">
    <div class="day-header">
      <div class="day-title">星期五 (Friday) - <span id="dayDate4"></span></div>
    </div>
    <div class="words-grid">
      <div class="word-item">
        <div class="word-number">1</div>
        <input type="text" id="day4_word1" placeholder="English">
        <input type="text" id="day4_chinese1" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">2</div>
        <input type="text" id="day4_word2" placeholder="English">
