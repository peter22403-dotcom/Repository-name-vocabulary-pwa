<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#667eea">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="背單字">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <title>📚 每週背單字確認表</title>
    <link rel="manifest" href="manifest.webmanifest">
    <link rel="icon" href="app-icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="app-icon.svg">
    <!-- 用於截圖的 library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            font-family: 'Microsoft JhengHei', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 0;
            padding: clamp(10px, 2vw, 20px);
            min-height: 100vh;
        }
        h1 {
            font-size: clamp(1.7rem, 4vw, 2.5rem);
            color: #333;
            text-align: center;
            margin-bottom: 10px;
        }
        .container {
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            padding: clamp(14px, 3vw, 30px);
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            overflow: hidden;
        }
        .header-info {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
            font-size: 1.1em;
        }
        .header-info > div {
            min-width: min(100%, 280px);
            flex: 1;
        }
        .child-name-select {
            width: min(100%, 220px);
            border: none;
            border-bottom: 2px solid #667eea;
            background: white;
            padding: 5px;
            font-size: 1.1em;
            border-radius: 0;
        }
        .child-name-select:focus {
            outline: none;
            border-bottom-color: #4caf50;
        }
        .day-section {
            margin-bottom: 30px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 15px;
            background-color: #f9f9f9;
        }
        .day-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .day-title {
            font-size: 1.3em;
            font-weight: bold;
        }
        .words-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
            gap: 10px;
            margin-bottom: 15px;
        }
        .word-item {
            display: grid;
            grid-template-columns: 30px minmax(0, 1fr) 42px minmax(0, 1fr);
            gap: 8px;
            align-items: center;
            padding: 8px;
            background: white;
            border-radius: 6px;
            border: 1px solid #ddd;
        }
        .word-number {
            font-weight: bold;
            color: #667eea;
            text-align: center;
        }
        .word-item input[type="text"] {
            width: 100%;
            min-width: 0;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1em;
        }
        .word-item input[type="text"]:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
        }
        .pronunciation-button {
            width: 42px;
            min-width: 42px;
            height: 40px;
            margin: 0;
            padding: 0;
            border-radius: 6px;
            font-size: 1.05em;
            line-height: 1;
            background: #4caf50;
            color: white;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .pronunciation-button:hover {
            box-shadow: 0 4px 12px rgba(76, 175, 80, 0.35);
        }
        .daily-confirm {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            padding: 12px;
            background: #fff3cd;
            border-radius: 6px;
            border: 2px solid #ffc107;
        }
        .daily-confirm > div {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            min-width: min(100%, 240px);
        }
        .daily-confirm label {
            font-weight: bold;
            margin-right: 10px;
        }
        .daily-confirm input[type="checkbox"] {
            width: 24px;
            height: 24px;
            cursor: pointer;
        }
        .daily-confirm input[type="text"] {
            flex: 1;
            min-width: 140px;
            padding: 6px;
            border: 1px solid #ccc;
            border-radius: 4px;
            margin-left: 0;
        }
        .signature-section {
            margin-top: 30px;
            padding: 20px;
            background: #e8f5e9;
            border-radius: 8px;
            border: 2px solid #4caf50;
        }
        .signature-section h3 {
            color: #2e7d32;
            margin-top: 0;
        }
        .signature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        .signature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .signature-item label {
            font-weight: bold;
            min-width: 120px;
        }
        .signature-item input {
            flex: 1;
            min-width: 0;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1em;
        }
        .summary {
            margin-top: 20px;
            padding: 15px;
            background: #fff;
            border-radius: 6px;
            font-size: 1.2em;
            text-align: center;
            font-weight: bold;
        }
        button {
            padding: 15px 25px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1.2em;
            margin: 8px 4px;
            transition: transform 0.2s;
            min-width: 120px;
            font-weight: bold;
        }
        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }
        button:active {
            transform: translateY(0px);
        }
        .button-group {
            text-align: center;
            margin-top: 20px;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 8px;
        }
        .save-status {
            min-height: 1.5em;
            margin-top: 10px;
            color: #2e7d32;
            font-weight: bold;
            text-align: center;
        }
        .backup-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.5);
            padding: 20px;
        }
        .backup-modal-content {
            background-color: #fefefe;
            padding: 20px;
            border-radius: 8px;
            max-width: 90%;
            margin: auto;
            max-height: 80vh;
            overflow-y: auto;
        }
        .close-modal {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            line-height: 20px;
        }
        .close-modal:hover,
        .close-modal:focus {
            color: black;
        }
        #backupText {
            width: 100%;
            height: 200px;
            padding: 10px;
            border: 2px solid #667eea;
            border-radius: 6px;
            font-family: monospace;
            font-size: 12px;
            resize: vertical;
        }
        #restoreText {
            width: 100%;
            height: 200px;
            padding: 10px;
            border: 2px solid #667eea;
            border-radius: 6px;
            font-family: monospace;
            font-size: 12px;
            resize: vertical;
        }
        .backup-buttons {
            margin-top: 15px;
            text-align: center;
        }
        .backup-buttons button {
            margin: 5px;
        }
        input,
        textarea,
        button {
            max-width: 100%;
        }
        @media (max-width: 760px) {
            .day-title {
                font-size: 1.05em;
            }
            .word-item {
                grid-template-columns: 28px minmax(0, 1fr) 42px;
            }
            .word-item input[id*="_word"] {
                grid-column: 2;
            }
            .pronunciation-button {
                grid-column: 3;
                width: 42px;
            }
            .word-item input[id*="_chinese"] {
                grid-column: 2 / 4;
            }
            button {
                width: 100%;
                margin: 4px 0;
                font-size: 1.05em;
            }
            .button-group {
                display: grid;
                grid-template-columns: 1fr;
            }
        }
        @media (min-width: 761px) and (max-width: 980px) {
            .words-grid {
                grid-template-columns: 1fr;
            }
            button {
                flex: 1 1 220px;
            }
        }
        @media print {
            body {
                background: white;
            }
            button {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📚 每週背單字確認表</h1>
        <div class="header-info">
            <div>
                <strong>小朋友姓名：</strong>
                <select id="childName" class="child-name-select" onchange="loadSelectedChildData()">
                    <option value="">請選擇</option>
                    <option value="彭威翰">彭威翰</option>
                    <option value="彭恩宣">彭恩宣</option>
                    <option value="彭威朗">彭威朗</option>
                </select>
            </div>
            <div>
                <strong>選擇週一日期：</strong>
                <input type="date" id="startDate" onchange="updateWeekDates()" style="padding:5px; font-size:1em; border:2px solid #667eea; border-radius:4px; max-width:100%;">
                <span id="weekRange" style="margin-left:10px; color:#666;"></span>
            </div>
        </div>

        <div id="weekDays">
  <div class="day-section">
    <div class="day-header">
      <div class="day-title">星期一 (Monday) - <span id="dayDate0"></span></div>
    </div>
    <div class="words-grid">
      <div class="word-item">
        <div class="word-number">1</div>
        <input type="text" id="day0_word1" placeholder="English">
        <input type="text" id="day0_chinese1" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">2</div>
        <input type="text" id="day0_word2" placeholder="English">
        <input type="text" id="day0_chinese2" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">3</div>
        <input type="text" id="day0_word3" placeholder="English">
        <input type="text" id="day0_chinese3" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">4</div>
        <input type="text" id="day0_word4" placeholder="English">
        <input type="text" id="day0_chinese4" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">5</div>
        <input type="text" id="day0_word5" placeholder="English">
        <input type="text" id="day0_chinese5" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">6</div>
        <input type="text" id="day0_word6" placeholder="English">
        <input type="text" id="day0_chinese6" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">7</div>
        <input type="text" id="day0_word7" placeholder="English">
        <input type="text" id="day0_chinese7" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">8</div>
        <input type="text" id="day0_word8" placeholder="English">
        <input type="text" id="day0_chinese8" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">9</div>
        <input type="text" id="day0_word9" placeholder="English">
        <input type="text" id="day0_chinese9" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">10</div>
        <input type="text" id="day0_word10" placeholder="English">
        <input type="text" id="day0_chinese10" placeholder="中文">
      </div>
    </div>
    <div class="daily-confirm">
      <div>
        <input type="checkbox" id="confirm_day0" onchange="updateCount()">
        <label for="confirm_day0">✅ 媽媽已確認（今日完成背誦）</label>
      </div>
      <div>
        <label>簽名：</label>
        <input type="text" id="sign_day0" placeholder="媽媽簽名">
      </div>
    </div>
  </div>
  <div class="day-section">
    <div class="day-header">
      <div class="day-title">星期二 (Tuesday) - <span id="dayDate1"></span></div>
    </div>
    <div class="words-grid">
      <div class="word-item">
        <div class="word-number">1</div>
        <input type="text" id="day1_word1" placeholder="English">
        <input type="text" id="day1_chinese1" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">2</div>
        <input type="text" id="day1_word2" placeholder="English">
