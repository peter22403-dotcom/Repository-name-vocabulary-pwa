            <div class="signature-grid">
                <div class="signature-item">
                    <label>媽媽簽名：</label>
                    <input type="text" id="mamaName" placeholder="請簽名">
                </div>
                <div class="signature-item">
                    <label>結算日期：</label>
                    <input type="date" id="dateConfirmed">
                </div>
                <div class="signature-item">
                    <label>完成天數：</label>
                    <input type="text" id="completedDays" readonly style="background:#f0f0f0;">
                </div>
                <div class="signature-item">
                    <label>零用錢金額：</label>
                    <input type="number" id="allowance" placeholder="$" min="0">
                </div>
            </div>
            <div class="summary" id="summary">
                本週完成 <span id="daysCount" style="color:#4caf50;">0</span> 天，太棒了！💪
            </div>
        </div>

        <div class="button-group">
            <button onclick="calculateAllowance()">🧮 計算完成天數</button>
            <button onclick="saveData()">💾 儲存資料</button>
            <button onclick="showBackupModal()">💬 備份文本</button>
            <button onclick="showRestoreModal()">📋 還原文本</button>
            <button onclick="printConfirmation()">🖨️ 列印確認表</button>
            <button onclick="endWeekAndArchive(event)" style="background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);">📸 週期結束 & 存檔</button>
        </div>
        <div id="saveStatus" class="save-status" aria-live="polite"></div>

        <!-- 備份文本模態框 -->
        <div id="backupModal" class="backup-modal">
            <div class="backup-modal-content">
                <span class="close-modal" onclick="closeBackupModal()">&times;</span>
                <h2>📋 備份文本</h2>
                <p>複製下方文本，可用郵件、Line等分享給家人備份：</p>
                <textarea id="backupText" readonly></textarea>
                <div class="backup-buttons">
                    <button onclick="copyBackupToClipboard()">📋 複製到剪貼簿</button>
                    <button onclick="closeBackupModal()">關閉</button>
                </div>
            </div>
        </div>

        <!-- 還原文本模態框 -->
        <div id="restoreModal" class="backup-modal">
            <div class="backup-modal-content">
                <span class="close-modal" onclick="closeRestoreModal()">&times;</span>
                <h2>📝 還原文本</h2>
                <p>將備份文本貼在下方：</p>
                <textarea id="restoreText" placeholder="貼上備份文本..."></textarea>
                <div class="backup-buttons">
                    <button onclick="restoreFromText()">✅ 還原資料</button>
                    <button onclick="clearRestoreText()">🗑️ 清除</button>
                    <button onclick="closeRestoreModal()">關閉</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const days = [
            { en: 'Monday', zh: '星期一', date: '' },
            { en: 'Tuesday', zh: '星期二', date: '' },
            { en: 'Wednesday', zh: '星期三', date: '' },
            { en: 'Thursday', zh: '星期四', date: '' },
            { en: 'Friday', zh: '星期五', date: '' },
            { en: 'Saturday', zh: '星期六', date: '' },
            { en: 'Sunday', zh: '星期日', date: '' }
        ];
        const GOOGLE_SHEETS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbzPaV7yJHYEbXKHkdJkWnFUQ7h0l23AzNfa-eNEpXt4lEX6v0imXJ5fvoZKJqCRZc8rlw/exec';

        function padDate(number) {
            return number.toString().padStart(2, '0');
        }

        function formatInputDate(date) {
            return `${date.getFullYear()}-${padDate(date.getMonth() + 1)}-${padDate(date.getDate())}`;
        }

        function setDateInputValue(input, date) {
            if (!input || !date || isNaN(date.getTime())) return;
            if ('valueAsDate' in input) {
                try {
                    input.valueAsDate = date;
                    return;
                } catch (error) {
                    // 部分瀏覽器不支援 valueAsDate，fallback 到字串格式
                }
            }
            input.value = formatInputDate(date);
        }

        function setChildNameValue(name) {
            const childNameSelect = document.getElementById('childName');
            if (!childNameSelect || !name) return;

            const hasOption = Array.from(childNameSelect.options).some(option => option.value === name);
            if (!hasOption) {
                childNameSelect.add(new Option(name, name));
            }

            childNameSelect.value = name;
        }

        // 初始化頁面
        async function init() {
            // 設定預設日期為當週週一
            const today = new Date();
            const monday = new Date(today);
            const dayOfWeek = today.getDay();
            const diff = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
            monday.setDate(today.getDate() + diff);
            
            // 設定開始日期選擇器
            const dateInput = document.getElementById('startDate');
            setDateInputValue(dateInput, monday);
            
            // 設定結算日期為今天
            setDateInputValue(document.getElementById('dateConfirmed'), today);
            
            // 初始生成週次表格
            generateWeekDays(monday);
            setupPronunciationButtons();
            
            // 嘗試載入儲存的資料
            await loadData();
        }

        // 更新週次日期
        function updateWeekDates() {
            const startDateInput = document.getElementById('startDate');
            if (!startDateInput || !startDateInput.value) return;

            const startDate = new Date(startDateInput.value);
            if (!isNaN(startDate.getTime())) {
                generateWeekDays(startDate);
            }
        }

        // 生成每日區塊日期
        function generateWeekDays(monday) {
            const sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            
            document.getElementById('weekRange').innerText = 
                `(${monday.toLocaleDateString()} ~ ${sunday.toLocaleDateString()})`;
            
            days.forEach((day, dayIndex) => {
                const dayDate = new Date(monday);
                dayDate.setDate(monday.getDate() + dayIndex);
                const formattedDate = dayDate.toLocaleDateString('zh-TW', { month: '2-digit', day: '2-digit' });
                const dateElement = document.getElementById(`dayDate${dayIndex}`);
                if (dateElement) {
                    dateElement.innerText = formattedDate;
                }
            });
        }

        function setupPronunciationButtons() {
            document.querySelectorAll('.word-item').forEach(item => {
                const englishInput = item.querySelector('input[id*="_word"]');
                if (!englishInput || item.querySelector('.pronunciation-button')) return;

                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'pronunciation-button';
                button.textContent = '🔊';
                button.title = '播放英文發音';
                button.setAttribute('aria-label', '播放英文發音');
                button.addEventListener('click', () => speakEnglishWord(englishInput));
                englishInput.insertAdjacentElement('afterend', button);
            });
        }

        function speakEnglishWord(input) {
            const word = input.value.trim();

            if (!word) {
                alert('請先輸入英文單字');
                input.focus();
                return;
            }

            if (!('speechSynthesis' in window)) {
                alert('這個瀏覽器不支援英文發音，請改用 Safari 或 Chrome。');
                return;
            }

            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(word);
            utterance.lang = 'en-US';
            utterance.rate = 0.85;
            window.speechSynthesis.speak(utterance);
        }

        // 計算完成天數
        function calculateAllowance() {
            let count = 0;
            for (let i = 0; i < 7; i++) {
                const checkbox = document.getElementById(`confirm_day${i}`);
                if (checkbox && checkbox.checked) {
                    count++;
                }
            }
            document.getElementById('daysCount').innerText = count;
            document.getElementById('completedDays').value = count + ' 天';
            
            // 可以設定零用錢計算規則，例如每天10元
            // document.getElementById('allowance').value = count * 10;
        }

        // 即時更新計數
        function updateCount() {
            calculateAllowance();
        }

        // 檢查 localStorage 是否可用
        function isLocalStorageAvailable() {
            try {
                const test = '__test__';
                localStorage.setItem(test, test);
                localStorage.removeItem(test);
                return true;
            } catch (e) {
                return false;
            }
        }

        function showSaveStatus(message, isError = false) {
            const status = document.getElementById('saveStatus');
            if (!status) return;
            status.innerText = message;
            status.style.color = isError ? '#c62828' : '#2e7d32';
        }

        function saveToLocalStorage(data) {
            if (!isLocalStorageAvailable()) return false;
            try {
                localStorage.setItem('vocabularyData', JSON.stringify(data));
                return true;
            } catch (e) {
                return false;
            }
        }

        function loadFromLocalStorage() {
            if (!isLocalStorageAvailable()) return null;
            const saved = localStorage.getItem('vocabularyData');
            if (!saved) return null;
            try {
                return JSON.parse(saved);
            } catch (e) {
                console.error('載入 localStorage 資料時發生錯誤:', e);
                return null;
            }
        }

        function withTimeout(promise, timeoutMs) {
            return Promise.race([
                promise,
                new Promise((_, reject) => {
                    setTimeout(() => reject(new Error('儲存逾時')), timeoutMs);
                })
            ]);
        }

        function canUseMacServer() {
            return false;
        }

        function canUseGoogleSheets() {
            return GOOGLE_SHEETS_WEB_APP_URL.startsWith('https://');
        }

        function loadFromGoogleSheets(childName) {
            if (!canUseGoogleSheets() || !childName) return Promise.resolve(null);

            return new Promise((resolve, reject) => {
                const callbackName = `vocabularyCallback_${Date.now()}_${Math.random().toString(16).slice(2)}`;
                const script = document.createElement('script');
                const timeout = setTimeout(() => {
                    cleanup();
                    reject(new Error('Google Sheets 讀取逾時'));
                }, 6000);

                function cleanup() {
                    clearTimeout(timeout);
                    delete window[callbackName];
                    if (script.parentNode) script.parentNode.removeChild(script);
                }

                window[callbackName] = response => {
                    cleanup();
                    if (!response || response.ok === false) {
                        resolve(null);
                        return;
                    }
                    resolve(response.data || null);
                };

                const params = new URLSearchParams({
                    action: 'load',
                    childName,
                    callback: callbackName
                });
                script.onerror = () => {
                    cleanup();
                    reject(new Error('Google Sheets 讀取失敗'));
                };
                script.src = `${GOOGLE_SHEETS_WEB_APP_URL}?${params.toString()}`;
                document.body.appendChild(script);
            });
        }

        async function sendToGoogleSheets(action, data) {
            if (!canUseGoogleSheets()) {
                throw new Error('尚未設定 Google Sheets Web App URL');
            }
            if (!data.childName) {
                throw new Error('請先選擇小朋友姓名');
            }

            await fetch(GOOGLE_SHEETS_WEB_APP_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify({ action, data })
            });

            return { ok: true };
        }

        async function saveToMacServer(data) {
            if (!canUseMacServer()) {
                throw new Error('不是由 Mac 伺服器開啟');
            }
            if (!data.childName) {
                throw new Error('請先選擇小朋友姓名');
            }

            const response = await fetch('/api/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                throw new Error('Mac 儲存失敗');
            }

            return response.json();
        }

        async function loadFromMacServer(childName) {
            if (!canUseMacServer() || !childName) return null;

            const response = await fetch(`/api/load?childName=${encodeURIComponent(childName)}`);
            if (response.status === 404) return null;
            if (!response.ok) {
                throw new Error('Mac 讀取失敗');
            }

            return response.json();
        }

        async function archiveToMacServer(data) {
            if (!canUseMacServer()) {
                throw new Error('不是由 Mac 伺服器開啟');
            }
            if (!data.childName) {
                throw new Error('請先選擇小朋友姓名');
            }

            const response = await fetch('/api/archive', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                throw new Error('Mac 封存失敗');
            }

            return response.json();
        }

        // 使用 IndexedDB 儲存（更可靠的方案）
        function saveToIndexedDB(data) {
            return new Promise((resolve, reject) => {
                try {
                    if (!window.indexedDB) {
                        reject(new Error('瀏覽器不支援 IndexedDB'));
                        return;
                    }

                    const request = indexedDB.open('VocabularyDB', 1);
                    
                    request.onerror = () => reject(new Error('IndexedDB 打開失敗'));
                    
                    request.onupgradeneeded = (event) => {
                        const db = event.target.result;
                        if (!db.objectStoreNames.contains('data')) {
                            db.createObjectStore('data');
                        }
                    };
                    
                    request.onsuccess = () => {
                        const db = request.result;
                        const transaction = db.transaction(['data'], 'readwrite');
                        const store = transaction.objectStore('data');
                        store.put(data, 'vocabularyData');
                        transaction.oncomplete = () => {
                            db.close();
                            resolve();
                        };
                        transaction.onerror = () => {
                            db.close();
                            reject(new Error('IndexedDB 寫入失敗'));
                        };
                    };
                } catch (e) {
                    reject(e);
                }
            });
        }

        // 從 IndexedDB 讀取
        function loadFromIndexedDB() {
            return new Promise((resolve, reject) => {
                try {
                    if (!window.indexedDB) {
                        reject(new Error('瀏覽器不支援 IndexedDB'));
                        return;
                    }

                    const request = indexedDB.open('VocabularyDB', 1);
                    
                    request.onerror = () => reject(new Error('IndexedDB 打開失敗'));

                    request.onupgradeneeded = (event) => {
                        const db = event.target.result;
                        if (!db.objectStoreNames.contains('data')) {
                            db.createObjectStore('data');
                        }
                    };
                    
                    request.onsuccess = () => {
                        try {
                            const db = request.result;
                            const transaction = db.transaction(['data'], 'readonly');
                            const store = transaction.objectStore('data');
                            const getRequest = store.get('vocabularyData');
                            
                            getRequest.onsuccess = () => {
                                db.close();
                                resolve(getRequest.result || null);
                            };
                            getRequest.onerror = () => {
                                db.close();
                                reject(new Error('IndexedDB 讀取失敗'));
                            };
                        } catch (e) {
                            reject(e);
                        }
                    };
                } catch (e) {
                    reject(e);
                }
            });
        }

        // 收集資料
        function collectData() {
            const data = {
                childName: document.getElementById('childName').value,
                mamaName: document.getElementById('mamaName').value,
                dateConfirmed: document.getElementById('dateConfirmed').value,
                allowance: document.getElementById('allowance').value,
                startDate: document.getElementById('startDate').value,
                weekRange: document.getElementById('weekRange').innerText,
                days: []
            };
            
            for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
                const dayData = {
                    confirmed: document.getElementById(`confirm_day${dayIndex}`).checked,
                    signature: document.getElementById(`sign_day${dayIndex}`).value,
                    words: []
                };
                
                for (let i = 1; i <= 10; i++) {
                    dayData.words.push({
                        english: document.getElementById(`day${dayIndex}_word${i}`).value,
                        chinese: document.getElementById(`day${dayIndex}_chinese${i}`).value
                    });
                }
                
                data.days.push(dayData);
            }
            
            return data;
        }

        // 儲存資料
        async function saveData() {
            const data = collectData();
            const localSaved = saveToLocalStorage(data);
            const now = new Date().toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
            let cloudSaved = false;
            let macSaved = false;
            
            if (localSaved) {
                showSaveStatus(`✅ 已先儲存在這台裝置：${now}`);
            } else {
                showSaveStatus('⚠️ 這個瀏覽器限制本機儲存，請使用「備份文本」。', true);
            }

            try {
                await withTimeout(sendToGoogleSheets('save', data), 6000);
                cloudSaved = true;
                showSaveStatus(`✅ 已儲存到 Google Sheets：${now}`);
            } catch (error) {
                console.log('Google Sheets 儲存失敗:', error);
            }

            try {
                await withTimeout(saveToMacServer(data), 2500);
                macSaved = true;
                if (!cloudSaved) {
                    showSaveStatus(`✅ 已儲存到 Mac：${now}`);
                }
            } catch (error) {
                console.log('Mac 儲存失敗:', error);
            }

            try {
                await withTimeout(saveToIndexedDB(data), 1500);
            } catch (error) {
                console.log('IndexedDB 儲存失敗:', error);
            }

            if (cloudSaved) {
                alert('✅ 資料已儲存到 Google Sheets！');
            } else if (macSaved) {
                alert('✅ 資料已儲存到 Mac！');
            } else if (localSaved) {
                alert('✅ 資料已儲存在這台裝置。\n\n⚠️ 但沒有存到 Google Sheets。請確認雲端設定。');
            } else {
                alert('❌ 無法儲存\n\n請確認已選擇小朋友姓名，並檢查雲端設定。');
            }
        }

        // 顯示備份模態框
        function showBackupModal() {
            const data = collectData();
            const backupText = JSON.stringify(data);
            document.getElementById('backupText').value = backupText;
            document.getElementById('backupModal').style.display = 'block';
        }

        // 關閉備份模態框
        function closeBackupModal() {
            document.getElementById('backupModal').style.display = 'none';
        }

        // 複製備份文本到剪貼簿
        function copyBackupToClipboard() {
            const textarea = document.getElementById('backupText');
            textarea.select();
            try {
                document.execCommand('copy');
                alert('✅ 已複製到剪貼簿！\n\n現在可以透過郵件、Line等分享給家人。');
            } catch (err) {
                alert('❌ 複製失敗，請手動複製文本。');
            }
        }

        // 顯示還原模態框
        function showRestoreModal() {
            document.getElementById('restoreText').value = '';
            document.getElementById('restoreModal').style.display = 'block';
        }

        // 關閉還原模態框
        function closeRestoreModal() {
            document.getElementById('restoreModal').style.display = 'none';
        }

        // 清除還原文本
        function clearRestoreText() {
            document.getElementById('restoreText').value = '';
        }

        // 從文本還原資料
        function restoreFromText() {
            const backupText = document.getElementById('restoreText').value.trim();
            if (!backupText) {
                alert('❌ 請先貼上備份文本！');
                return;
            }
            
            try {
                const data = JSON.parse(backupText);
                applyLoadedData(data);
                
                // 同時保存到本地
                saveToLocalStorage(data);
                sendToGoogleSheets('save', data).catch(() => {});
                saveToMacServer(data).catch(() => {});
                saveToIndexedDB(data).catch(() => {});
                
                closeRestoreModal();
                alert('✅ 資料已成功還原！');
            } catch (error) {
                alert('❌ 文本格式錯誤，請確保貼上的是完整的備份文本。\n\n錯誤: ' + error.message);
            }
        }

        // 套用已載入的資料
        function applyLoadedData(data) {
            try {
                if (data.childName) setChildNameValue(data.childName);
                if (data.mamaName) document.getElementById('mamaName').value = data.mamaName;
                if (data.dateConfirmed) document.getElementById('dateConfirmed').value = data.dateConfirmed;
                if (data.allowance) document.getElementById('allowance').value = data.allowance;
                if (data.startDate) {
                    document.getElementById('startDate').value = data.startDate;
                    updateWeekDates();
                }
                
                if (data.days && data.days.length === 7) {
                    for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
                        const dayData = data.days[dayIndex];
                        
                        const confirmCheckbox = document.getElementById(`confirm_day${dayIndex}`);
                        if (confirmCheckbox) confirmCheckbox.checked = dayData.confirmed || false;
                        
                        const signInput = document.getElementById(`sign_day${dayIndex}`);
                        if (signInput) signInput.value = dayData.signature || '';
                        
                        if (dayData.words) {
                            for (let i = 0; i < dayData.words.length && i < 10; i++) {
                                const word = dayData.words[i];
                                const englishInput = document.getElementById(`day${dayIndex}_word${i + 1}`);
                                const chineseInput = document.getElementById(`day${dayIndex}_chinese${i + 1}`);
                                
                                if (englishInput) englishInput.value = word.english || '';
                                if (chineseInput) chineseInput.value = word.chinese || '';
                            }
                        }
                    }
                }
                
                calculateAllowance();
            } catch (e) {
                console.error('套用資料時發生錯誤:', e);
            }
        }

        // 載入儲存的資料
        async function loadData() {
            const localData = loadFromLocalStorage();
            if (localData) {
                applyLoadedData(localData);
            }

            try {
                const idbData = await withTimeout(loadFromIndexedDB(), 1500);
                if (idbData) {
                    applyLoadedData(idbData);
                }
            } catch (err) {
                console.log('IndexedDB 讀取失敗或逾時，使用 localStorage 資料');
            }

            const childName = document.getElementById('childName').value;
            if (childName) {
                await loadSelectedChildData(false);
            }
        }

        async function loadSelectedChildData(showMissingMessage = true) {
            const childName = document.getElementById('childName').value;
            if (!childName) return;

            try {
                const cloudData = await withTimeout(loadFromGoogleSheets(childName), 6000);
                if (cloudData) {
                    applyLoadedData(cloudData);
                    showSaveStatus(`✅ 已從 Google Sheets 載入：${childName}`);
                    return;
                }
            } catch (error) {
                console.log('Google Sheets 讀取失敗:', error);
            }

            if (showMissingMessage) {
                showSaveStatus(`尚未找到 ${childName} 的 Google Sheets 儲存資料`);
            }
        }

        // 列印
        function printConfirmation() {
            window.print();
        }

        // 週期結束 & 存檔 - 截圖並清空
        async function endWeekAndArchive(event) {
            const childName = document.getElementById('childName').value || '未命名';
            const startDate = document.getElementById('startDate').value;
            
            if (!startDate) {
                alert('❌ 請先選擇週一日期！');
                return;
            }
            
            // 確認
            const confirmed = confirm(
                `確認結束本週期嗎？\n\n小孩：${childName}\n週期：${startDate} 開始\n\n✅ 會存檔整個表格為圖片\n🗑️ 然後清空所有資料`
            );
            
            if (!confirmed) return;
            
            try {
                const btn = event && event.target ? event.target : null;
                const originalText = btn ? btn.innerHTML : '';
                if (btn) {
                    btn.innerHTML = '⏳ 正在封存...';
                    btn.disabled = true;
                }

                const archiveData = collectData();
                archiveData.archivedAt = new Date().toISOString();
                archiveData.archiveType = 'week-end';
                archiveData.completedDays = document.getElementById('completedDays').value;

                let archiveResult = null;
                let archiveTarget = '';
                try {
                    archiveResult = await withTimeout(sendToGoogleSheets('archive', archiveData), 6000);
                    archiveTarget = 'Google Sheets';
                    showSaveStatus(`✅ 已封存到 Google Sheets：${childName}`);
                } catch (cloudArchiveError) {
                    console.log('Google Sheets 封存失敗:', cloudArchiveError);
                }

                try {
                    if (archiveTarget) throw new Error('已完成雲端封存');
                    archiveResult = await withTimeout(archiveToMacServer(archiveData), 4000);
                    archiveTarget = 'Mac';
                    showSaveStatus(`✅ 已封存到 Mac：${childName}`);
                } catch (archiveError) {
                    if (!archiveTarget) {
                        console.error('封存失敗:', archiveError);
                        if (btn) {
                            btn.innerHTML = originalText;
                            btn.disabled = false;
                        }
                        alert('❌ 沒有成功封存到 Google Sheets，所以不會清空資料。\n\n請確認雲端設定。');
                        return;
                    }
                }

                let imageSaved = false;
                let fileName = '';
                
                if (typeof html2canvas !== 'undefined') {
                    if (btn) btn.innerHTML = '⏳ 正在截圖...';

                    const buttonGroup = document.querySelector('.button-group');
                    buttonGroup.style.display = 'none';
                    await new Promise(resolve => setTimeout(resolve, 100));

                    const canvas = await html2canvas(document.querySelector('.container'), {
                        scale: 2,
                        backgroundColor: '#ffffff',
                        logging: false,
                        useCORS: true
                    });

                    buttonGroup.style.display = 'flex';

                    const dateStr = new Date().toLocaleDateString('zh-TW').replace(/\//g, '-');
                    fileName = `背單字紀錄_${childName}_${startDate}_${dateStr}.png`;

                    const blob = await new Promise(resolve => canvas.toBlob(resolve));
                    if (blob) {
                        const url = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = fileName;
                        link.click();
                        URL.revokeObjectURL(url);
                        imageSaved = true;
                    }
                }

                clearAllData();
                saveToLocalStorage(collectData());

                if (btn) {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }

                const archiveFile = archiveResult && archiveResult.file ? archiveResult.file : `${archiveTarget} 封存紀錄`;
                alert(
                    `✅ 本週資料已封存到 ${archiveTarget}！\n\n紀錄檔：${archiveFile}` +
                    (imageSaved ? `\n截圖：${fileName}` : '\n截圖：未產生，但 JSON 紀錄已保存') +
                    '\n\n表格已清空，可開始新週期。'
                );
            } catch (error) {
                console.error('截圖失敗:', error);
                alert('❌ 封存流程失敗，資料不會清空。\n\n' + error.message);
                
                const btn = event && event.target ? event.target : null;
                if (btn) {
                    btn.innerHTML = '📸 週期結束 & 存檔';
                    btn.disabled = false;
                }
                const buttonGroup = document.querySelector('.button-group');
                if (buttonGroup) buttonGroup.style.display = 'flex';
            }
        }

        // 清空表單
        function clearAllData() {
            // 清空文字輸入
            document.getElementById('childName').value = '';
            document.getElementById('mamaName').value = '';
            document.getElementById('allowance').value = '';
            document.getElementById('completedDays').value = '';
            
            // 清空每日資料
            for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
                const confirmCheckbox = document.getElementById(`confirm_day${dayIndex}`);
                if (confirmCheckbox) confirmCheckbox.checked = false;
                
                const signInput = document.getElementById(`sign_day${dayIndex}`);
                if (signInput) signInput.value = '';
                
                for (let i = 1; i <= 10; i++) {
                    const englishInput = document.getElementById(`day${dayIndex}_word${i}`);
                    const chineseInput = document.getElementById(`day${dayIndex}_chinese${i}`);
                    
                    if (englishInput) englishInput.value = '';
                    if (chineseInput) chineseInput.value = '';
                }
            }
            
            // 重置計數
            document.getElementById('daysCount').innerText = '0';
            
            // 設定為下週的週一日期
            const today = new Date();
            const nextMonday = new Date(today);
            const dayOfWeek = today.getDay();
            const diff = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;
            nextMonday.setDate(today.getDate() + diff);
            
            const dateInput = document.getElementById('startDate');
            setDateInputValue(dateInput, nextMonday);
            
            // 更新週次顯示
            generateWeekDays(nextMonday);
            
            // 清除本地儲存
            try {
                localStorage.removeItem('vocabularyData');
            } catch (e) {
                // 忽略錯誤
            }
            
            // 清除 IndexedDB
            try {
                const request = indexedDB.open('VocabularyDB', 1);
                request.onsuccess = () => {
                    const db = request.result;
                    const transaction = db.transaction(['data'], 'readwrite');
                    const store = transaction.objectStore('data');
                    store.delete('vocabularyData');
                };
            } catch (e) {
                // 忽略錯誤
            }
        }

        // 頁面載入時初始化
        window.onload = init;

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('./sw.js').catch(error => {
                    console.log('Service worker 註冊失敗:', error);
                });
            });
        }
        
        // 點擊模態框外面時關閉
        window.onclick = function(event) {
            const backupModal = document.getElementById('backupModal');
            const restoreModal = document.getElementById('restoreModal');
            
            if (event.target === backupModal) {
                backupModal.style.display = 'none';
            }
            if (event.target === restoreModal) {
                restoreModal.style.display = 'none';
            }
        }
    </script>
</body>
</html>
