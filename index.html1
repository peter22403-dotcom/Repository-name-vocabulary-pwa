      <div class="word-item">
        <div class="word-number">3</div>
        <input type="text" id="day2_word3" placeholder="English">
        <input type="text" id="day2_chinese3" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">4</div>
        <input type="text" id="day2_word4" placeholder="English">
        <input type="text" id="day2_chinese4" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">5</div>
        <input type="text" id="day2_word5" placeholder="English">
        <input type="text" id="day2_chinese5" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">6</div>
        <input type="text" id="day2_word6" placeholder="English">
        <input type="text" id="day2_chinese6" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">7</div>
        <input type="text" id="day2_word7" placeholder="English">
        <input type="text" id="day2_chinese7" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">8</div>
        <input type="text" id="day2_word8" placeholder="English">
        <input type="text" id="day2_chinese8" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">9</div>
        <input type="text" id="day2_word9" placeholder="English">
        <input type="text" id="day2_chinese9" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">10</div>
        <input type="text" id="day2_word10" placeholder="English">
        <input type="text" id="day2_chinese10" placeholder="中文">
      </div>
    </div>
    <div class="daily-confirm">
      <div>
        <input type="checkbox" id="confirm_day2" onchange="updateCount()">
        <label for="confirm_day2">✅ 媽媽已確認（今日完成背誦）</label>
      </div>
      <div>
        <label>簽名：</label>
        <input type="text" id="sign_day2" placeholder="媽媽簽名">
      </div>
    </div>
  </div>
  <div class="day-section">
    <div class="day-header">
      <div class="day-title">星期四 (Thursday) - <span id="dayDate3"></span></div>
    </div>
    <div class="words-grid">
      <div class="word-item">
        <div class="word-number">1</div>
        <input type="text" id="day3_word1" placeholder="English">
        <input type="text" id="day3_chinese1" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">2</div>
        <input type="text" id="day3_word2" placeholder="English">
        <input type="text" id="day3_chinese2" placeholder="中文">
