        <input type="text" id="day1_chinese3" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">4</div>
        <input type="text" id="day1_word4" placeholder="English">
        <input type="text" id="day1_chinese4" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">5</div>
        <input type="text" id="day1_word5" placeholder="English">
        <input type="text" id="day1_chinese5" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">6</div>
        <input type="text" id="day1_word6" placeholder="English">
        <input type="text" id="day1_chinese6" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">7</div>
        <input type="text" id="day1_word7" placeholder="English">
        <input type="text" id="day1_chinese7" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">8</div>
        <input type="text" id="day1_word8" placeholder="English">
        <input type="text" id="day1_chinese8" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">9</div>
        <input type="text" id="day1_word9" placeholder="English">
        <input type="text" id="day1_chinese9" placeholder="中文">
      </div>
      <div class="word-item">
        <div class="word-number">10</div>
