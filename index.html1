    </div>
    <div class="daily-confirm">
      <div>
        <input type="checkbox" id="confirm_day1" onchange="updateCount()">
        <label for="confirm_day1">✅ 媽媽已確認（今日完成背誦）</label>
      </div>
      <div>
        <label>簽名：</label>
        <input type="text" id="sign_day1" placeholder="媽媽簽名">
      </div>
    </div>
  </div>
  <div class="day-section">
    <div class="day-header">
      <div class="day-title">星期三 (Wednesday) - <span id="dayDate2"></span></div>
    </div>
    <div class="words-grid">
      <div class="word-item">
